[
  // Ignore these in the terminal, so things work like when in Alacritty.
  {
    "key": "ctrl+e",
    "command": "-workbench.action.quickOpen",
    "when": "terminalFocus"
  },
  // Terminal commands
  // toggle panel ctrl+j
  {
    "key": "shift+alt+t",
    "command": "workbench.action.terminal.new"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+.",
    "command": "workbench.action.positionPanelRight"
  },
  {
    "key": "ctrl+shift+,",
    "command": "workbench.action.positionPanelBottom"
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.toggleMaximizedPanel",
    "when": "terminalFocus"
  },
  {
    "key": "alt+shift+j",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus"
  },
  {
    "key": "alt+shift+k",
    "command": "workbench.action.terminal.focusPreviousPane",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.terminal.focusNext"
  },
  {
    "key": "ctrl+shift+k",
    "command": "workbench.action.terminal.focusPrevious"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus"
  },
  // terminal removals to work like expected
  {
    "key": "ctrl+shift+`",
    "command": "-workbench.action.terminal.new"
  },
  {
    "key": "ctrl+f",
    "command": "-workbench.action.terminal.focusFindWidget",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+f",
    "command": "-workbench.action.terminal.focusFindWidget",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+f",
    "command": "-workbench.action.terminal.focusFindWidget",
    "when": "terminalFindWidgetFocused"
  },
  {
    "key": "ctrl+t",
    "command": "-editor.action.transposeLetters",
    "when": "textInputFocus && !editorReadonly"
  },
  {
    "key": "ctrl+shift+t",
    "command": "-workbench.action.reopenClosedEditor"
  },
  // I'm used to this in emacs
  {
    "key": "alt+g alt+g",
    "command": "workbench.action.gotoLine",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+k ctrl+o",
    "command": "-workbench.action.files.openFolder"
  },
  {
    "key": "ctrl+x j",
    "command": "workbench.action.togglePanel"
  },
  {
    "key": "ctrl+shift+y",
    "command": "-workbench.debug.action.toggleRepl"
  },
  {
    "key": "ctrl+x d",
    "command": "workbench.debug.action.toggleRepl"
  },
  {
    "key": "ctrl+shift+m",
    "command": "-workbench.actions.view.problems"
  },
  {
    "key": "ctrl+x p",
    "command": "workbench.actions.view.problems"
  },
  {
    "key": "ctrl+x b",
    "command": "workbench.action.showAllEditors"
  },
  {
    "key": "shift+alt+p",
    "command": "editor.action.insertCursorAbove",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+up",
    "command": "-editor.action.insertCursorAbove",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+alt+n",
    "command": "editor.action.insertCursorBelow",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+down",
    "command": "-editor.action.insertCursorBelow",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+x n",
    "command": "workbench.action.files.newUntitledFile"
  },
  {
    "key": "ctrl+n",
    "command": "-workbench.action.files.newUntitledFile"
  },
  // Golang stuff
  {
    "key": "alt+g alt+f",
    "command": "go.test.generate.function"
  },
  {
    "key": "alt+g alt+t",
    "command": "go.test.cursor"
  },
  {
    "key": "alt+g alt+d",
    "command": "go.debug.cursor"
  },
  {
    "key": "alt+g alt+shift+t",
    "command": "go.test.file"
  },
  {
    "key": "alt+g alt+c",
    "command": "go.test.coverage"
  },
  {
    "key": "ctrl+shift+x ctrl+shift+s",
    "command": "workbench.action.files.saveAll"
  },
  {
    "key": "ctrl+shift+k",
    "command": "-editor.action.deleteLines",
    "when": "textInputFocus && !editorReadonly"
  },
  {
    "key": "ctrl+shift+j",
    "command": "-workbench.action.search.toggleQueryDetails",
    "when": "inSearchEditor || searchViewletFocus"
  },
  {
    "key": "ctrl+x f",
    "command": "workbench.action.files.openFolder"
  }
]